* text=auto eol=lf

*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Cryptographically pinned build material must hash identically on every runner.
/third_party/sidecars/semgrep/build-public-source-windows.ps1 text eol=lf

*.bmp binary
*.gif binary
*.ico binary
*.jpeg binary
*.jpg binary
*.png binary
*.webp binary
*.avif binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.zip binary
*.gz binary
*.tgz binary
*.bz2 binary
*.7z binary
*.rar binary
*.tar binary
*.pdf binary

# Upstream Gitleaks policy is byte-pinned with its published CRLF bytes.
/third_party/sidecars/policies/gitleaks.toml -text whitespace=-trailing-space
