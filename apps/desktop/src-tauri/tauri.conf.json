{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Context Relay",
  "version": "0.1.0",
  "identifier": "com.skytuhua.contextrelay",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
    },
    "windows": [
      {
        "title": "Context Relay",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600
      }
    ]
  },
  "bundle": {
    "active": false
  }
}
