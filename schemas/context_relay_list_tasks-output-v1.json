{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "tasks": {
      "items": {
        "additionalProperties": false,
        "allOf": [
          {
            "if": {
              "properties": {
                "status": {
                  "const": "done"
                }
              },
              "required": [
                "status"
              ]
            },
            "then": {
              "properties": {
                "evidence": {
                  "minItems": 1,
                  "type": "array"
                }
              }
            }
          }
        ],
        "properties": {
          "bodyMarkdown": {
            "maxLength": 1048576,
            "minLength": 1,
            "pattern": ".*\\S.*",
            "type": "string",
            "x-utf8-maxBytes": 1048576
          },
          "evidence": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "evidenceKind": {
                  "maxLength": 128,
                  "minLength": 1,
                  "pattern": ".*\\S.*",
                  "type": "string",
                  "x-utf8-maxBytes": 128
                },
                "recordedHlc": {
                  "additionalProperties": false,
                  "properties": {
                    "logical": {
                      "maximum": 4294967295,
                      "minimum": 0,
                      "type": "integer"
                    },
                    "node": {
                      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
                      "type": "string"
                    },
                    "physicalMs": {
                      "pattern": "^(?:0|[1-9][0-9]{0,18}|1[0-7][0-9]{18}|18[0-3][0-9]{17}|184[0-3][0-9]{16}|1844[0-5][0-9]{15}|18446[0-6][0-9]{14}|184467[0-3][0-9]{13}|1844674[0-3][0-9]{12}|184467440[0-6][0-9]{10}|1844674407[0-2][0-9]{9}|18446744073[0-6][0-9]{8}|1844674407370[0-8][0-9]{6}|18446744073709[0-4][0-9]{5}|184467440737095[0-4][0-9]{4}|18446744073709550[0-9]{3}|18446744073709551[0-5][0-9]{2}|1844674407370955160[0-9]|1844674407370955161[0-5])$",
                      "type": "string"
                    }
                  },
                  "required": [
                    "physicalMs",
                    "logical",
                    "node"
                  ],
                  "type": "object"
                },
                "reference": {
                  "oneOf": [
                    {
                      "type": "null"
                    },
                    {
                      "maxLength": 16384,
                      "type": "string",
                      "x-utf8-maxBytes": 16384
                    }
                  ]
                },
                "summary": {
                  "maxLength": 16384,
                  "minLength": 1,
                  "pattern": ".*\\S.*",
                  "type": "string",
                  "x-utf8-maxBytes": 16384
                }
              },
              "required": [
                "summary",
                "evidenceKind",
                "reference",
                "recordedHlc"
              ],
              "type": "object"
            },
            "maxItems": 64,
            "type": "array"
          },
          "id": {
            "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
            "type": "string"
          },
          "projectId": {
            "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
            "type": "string"
          },
          "revision": {
            "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
            "type": "string"
          },
          "status": {
            "enum": [
              "open",
              "in_progress",
              "blocked",
              "done",
              "canceled"
            ]
          },
          "title": {
            "maxLength": 512,
            "minLength": 1,
            "pattern": ".*\\S.*",
            "type": "string",
            "x-utf8-maxBytes": 512
          }
        },
        "required": [
          "id",
          "projectId",
          "title",
          "bodyMarkdown",
          "status",
          "evidence",
          "revision"
        ],
        "type": "object"
      },
      "maxItems": 10000,
      "type": "array"
    }
  },
  "required": [
    "tasks"
  ],
  "type": "object"
}
