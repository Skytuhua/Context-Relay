{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "evidence": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "kind": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": ".*\\S.*",
            "type": "string"
          },
          "reference": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "maxLength": 16384,
                "type": "string"
              }
            ]
          },
          "summary": {
            "maxLength": 16384,
            "minLength": 1,
            "pattern": ".*\\S.*",
            "type": "string"
          }
        },
        "required": [
          "summary",
          "kind"
        ],
        "type": "object"
      },
      "maxItems": 64,
      "minItems": 1,
      "type": "array"
    },
    "expectedRevision": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "operationId": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "taskId": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    }
  },
  "required": [
    "operationId",
    "taskId",
    "expectedRevision",
    "evidence"
  ],
  "type": "object"
}
