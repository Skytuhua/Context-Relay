{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "limit": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "maximum": 100,
          "minimum": 1,
          "type": "integer"
        }
      ]
    },
    "query": {
      "maxLength": 1048576,
      "minLength": 1,
      "pattern": ".*\\S.*",
      "type": "string",
      "x-utf8-maxBytes": 1048576
    },
    "scope": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "oneOf": [
            {
              "additionalProperties": false,
              "properties": {
                "scope": {
                  "const": "global"
                }
              },
              "required": [
                "scope"
              ],
              "type": "object"
            },
            {
              "additionalProperties": false,
              "properties": {
                "scope": {
                  "const": "active_project"
                }
              },
              "required": [
                "scope"
              ],
              "type": "object"
            }
          ]
        }
      ]
    }
  },
  "required": [
    "query"
  ],
  "type": "object"
}
