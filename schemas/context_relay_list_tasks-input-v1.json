{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "projectId": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
          "type": "string"
        }
      ]
    },
    "status": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "enum": [
            "open",
            "in_progress",
            "blocked",
            "done",
            "canceled"
          ]
        }
      ]
    }
  },
  "required": [],
  "type": "object"
}
